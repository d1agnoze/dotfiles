{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "autoupdate": true,
  "lsp": true,
  "instructions": [
    ".config/opencode/*.md",
    ".config/opencode/instructions/*.md"
  ],
  "plugin": ["@slkiser/opencode-quota", "@mohak34/opencode-notifier"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "tmux": {
      "type": "local",
      "command": [
        "tmuxmcpd",
        "--listen",
        "127.0.0.1:46321",
        "--history-lines",
        "500"
      ],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/github_token}"
      },
      "enabled": false
    },
    "jam": {
      "type": "remote",
      "url": "https://mcp.jam.dev/mcp",
      "enabled": false
    },
    "shopify-dev-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@shopify/dev-mcp@latest"],
      "enabled": false
    }
  }
}
